    async function saveEmployee(employeeId, options = {}) {
      const skipReload = !!options.skipReload;
      const silent = !!options.silent;
      if (!adminPin) {
        if (!silent) setText('employee-manage-msg', tAdmin('a_msg_admin_required'), true);
        return false;
      }

      const draft = getEmployeeRowDraft(employeeId);
      if (!draft) {
        if (!silent) setText('employee-manage-msg', 'row not found', true);
        return false;
      }

      if (!draft.name || !draft.hire_date) {
        if (!silent) setText('employee-manage-msg', tAdmin('a_msg_name_hire_required'), true);
        return false;
      }

      try {
        const res = await fetch(`/api/admin/employees/${encodeURIComponent(employeeId)}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            admin_pin: adminPin,
            name: draft.name,
            adp_mapping_code: draft.adp_mapping_code,
            hire_date: draft.hire_date,
            termination_date: draft.termination_date,
            title: draft.title,
            work_group: draft.work_group,
            is_active: draft.is_active,
          }),
        });
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_employee_update_failed'));

        if (!skipReload) {
          setText('employee-manage-msg', tAdmin('a_msg_saved'));
          await loadAdminEmployees();
        } else {
          updateEmployeeBulkSaveBtn();
        }
        return true;
      } catch (err) {
        if (!silent) setText('employee-manage-msg', err.message, true);
        return false;
      }
    }

    async function saveEmployeesBulk() {
      if (!adminPin) {
        setText('employee-manage-msg', tAdmin('a_msg_admin_required'), true);
        return;
      }

      const dirtyIds = collectDirtyEmployeeIds();
      if (!dirtyIds.length) {
        setText('employee-manage-msg', adminLang() === 'ko' ? '변경된 항목이 없습니다.' : 'No pending changes.');
        updateEmployeeBulkSaveBtn();
        return;
      }

      setText('employee-manage-msg', adminLang() === 'ko' ? `일괄 저장 중... (${dirtyIds.length}건)` : `Saving changes... (${dirtyIds.length})`);

      let successCount = 0;
      let failCount = 0;
      for (const employeeId of dirtyIds) {
        const ok = await saveEmployee(employeeId, { skipReload: true, silent: true });
        if (ok) successCount += 1;
        else failCount += 1;
      }

      await loadAdminEmployees();

      if (failCount === 0) {
        setText('employee-manage-msg', adminLang() === 'ko' ? `일괄 저장 완료: ${successCount}건` : `Saved ${successCount} change(s).`);
      } else {
        setText('employee-manage-msg', adminLang() === 'ko' ? `부분 저장: 성공 ${successCount}건 / 실패 ${failCount}건` : `Partial save: ${successCount} succeeded / ${failCount} failed`, true);
      }
    }

