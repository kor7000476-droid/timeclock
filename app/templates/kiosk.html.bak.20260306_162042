    async function queryEvents() {
      if (!adminPin) {
        setText('query-msg', tAdmin('a_msg_admin_required'), true);
        return;
      }

      const q = document.getElementById('query-q').value.trim();
      const start = document.getElementById('query-start').value;
      const end = document.getElementById('query-end').value;
      if (!start || !end) {
        setText('query-msg', tAdmin('a_msg_need_query_dates'), true);
        setQueryVisibility(false);
        return;
      }

      setText('query-msg', tAdmin('a_msg_searching'));
      setQueryVisibility(false);

      const url = `/api/admin/events/query?admin_pin=${encodeURIComponent(adminPin)}&start_date=${encodeURIComponent(start)}&end_date=${encodeURIComponent(end)}&q=${encodeURIComponent(q)}`;
      try {
        const res = await fetch(url);
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_query_failed'));

        const summaries = data.summaries || [];
        const events = data.events || [];
        const matched = Number(data.matched_employees || 0);

        if (matched === 0) {
          setText('query-msg', tAdmin('a_msg_no_results'), true);
          setQueryVisibility(false);
          return;
        }

        let totalWork = 0;
        let totalBreak = 0;
        const dayMap = new Map(); // yyyy-mm-dd => {work, break}
        for (const s of summaries) {
          totalWork += Number(s.total_work_minutes || 0);
          totalBreak += Number(s.total_break_minutes || 0);
          for (const d of (s.days || [])) {
            const key = d.work_date;
            const cur = dayMap.get(key) || { work: 0, break: 0 };
            cur.work += Number(d.work_minutes || 0);
            cur.break += Number(d.break_minutes || 0);
            dayMap.set(key, cur);
          }
        }

        const dayKeys = Array.from(dayMap.keys()).sort();
        const summaryEl = document.getElementById('query-summary');

        const L = adminLang() === 'ko'
          ? {
              employees: '직원',
              period: '기간',
              period_total: '기간 합계',
              work: '근무',
              break: '브레이크',
              date: '일자',
              flags: '플래그',
            }
          : {
              employees: 'Employees',
              period: 'Period',
              period_total: 'Period Total',
              work: 'Work',
              break: 'Break',
              date: 'Date',
              flags: 'Flags',
            };

        let html = '';
        html += `<div class="summary-line"><span class="pill">${L.employees} ${matched}</span><span class="pill">${L.period} ${start} ~ ${end}</span></div>`;
        html += `<div class="summary-line" style="margin-top:6px;"><div><b>${L.period_total}</b> ${L.work} ${minutesToHours(totalWork)} (${fmtMinutes(totalWork)})</div><div><b>${L.break}</b> ${minutesToHours(totalBreak)} (${fmtMinutes(totalBreak)})</div></div>`;

        html += `<div style="margin-top:8px; max-height:220px; overflow:auto;">`;
        html += `<table class="tight"><thead><tr><th>${L.date}</th><th>${L.work}</th><th>${L.break}</th></tr></thead><tbody>`;
        for (const k of dayKeys) {
          const v = dayMap.get(k);
          html += `<tr><td>${k}</td><td>${minutesToHours(v.work)} (${fmtMinutes(v.work)})</td><td>${minutesToHours(v.break)} (${fmtMinutes(v.break)})</td></tr>`;
        }
        html += `</tbody></table></div>`;

        for (const s of summaries) {
          const title = s.title || 'STAFF';
          html += `<details class="emp-summary">`;
          html += `<summary><span class="summary-line"><span>${s.employee_name} (${s.employee_code})</span><span class="pill">${title}</span><span class="pill">${L.work} ${minutesToHours(s.total_work_minutes)} </span><span class="pill">${L.break} ${minutesToHours(s.total_break_minutes)}</span></span></summary>`;
          html += `<div style="margin-top:8px; max-height:220px; overflow:auto;">`;
          html += `<table class="tight"><thead><tr><th>${L.date}</th><th>${L.work}</th><th>${L.break}</th><th>${L.flags}</th></tr></thead><tbody>`;
          for (const d of (s.days || [])) {
            const flags = (d.flags || []).join(', ');
            html += `<tr><td>${d.work_date}</td><td>${minutesToHours(d.work_minutes)} (${fmtMinutes(d.work_minutes)})</td><td>${minutesToHours(d.break_minutes)} (${fmtMinutes(d.break_minutes)})</td><td>${flags}</td></tr>`;
          }
          html += `</tbody></table></div>`;
          html += `</details>`;
        }

        summaryEl.innerHTML = html;

        const tbody = document.getElementById('query-events-body');
        tbody.innerHTML = '';
        for (const row of events) {
          const tr = document.createElement('tr');
          tr.innerHTML = `<td>${utcIsoToLocal(row.ts_utc)}</td><td>${row.employee_code}</td><td>${row.employee_name}</td><td>${row.title || ''}</td><td>${row.event_type}</td><td>${row.method}</td>`;
          tbody.appendChild(tr);
        }

        setText(
          'query-msg',
          adminLang() === 'ko'
            ? `조회 완료: 직원 ${matched}명, 이벤트 ${events.length}건`
            : `Done: employees ${matched}, events ${events.length}`
        );
        setQueryVisibility(true);
      } catch (err) {
        setText('query-msg', err.message, true);
        setQueryVisibility(false);
      }
    }

    function downloadCsv() {
      const start = document.getElementById('start-date').value;
      const end = document.getElementById('end-date').value;
      if (!start || !end) {
        setText('csv-msg', tAdmin('a_msg_need_pay_dates'), true);
        return;
      }
      window.location.href = `/api/reports/pay-period.csv?start_date=${start}&end_date=${end}`;
      setText('csv-msg', tAdmin('a_msg_csv_download_started'));
    }

	    async function emailCsv() {
      const start = document.getElementById('start-date').value;
      const end = document.getElementById('end-date').value;
      const toEmail = document.getElementById('payroll-email-to').value.trim();
      if (!start || !end || !toEmail) {
        setText('csv-msg', tAdmin('a_msg_need_dates_email'), true);
        return;
      }

      try {
        const res = await fetch('/api/reports/pay-period/email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ start_date: start, end_date: end, to_email: toEmail }),
        });
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_email_failed'));
        // Success popup for 1.5s.
        showTransientPopup(
          uiLang === 'ko' ? '성공' : (uiLang === 'es' ? 'Exito' : 'Success'),
          '',
          1500
        );
        setText('csv-msg', tAdmin('a_msg_email_sent'));
      } catch (err) {
        setText('csv-msg', err.message, true);
      }
    }

    function openResetModal() {
      if (!adminPin) {
        setText('reset-msg', tAdmin('a_msg_admin_required'), true);
        return;
      }
      document.getElementById('reset-modal-msg').textContent = '';
      document.getElementById('reset-password').value = '';
      document.getElementById('reset-modal-backdrop').classList.remove('hidden');
      setTimeout(() => document.getElementById('reset-password').focus(), 50);
    }

    function closeResetModal() {
      document.getElementById('reset-modal-backdrop').classList.add('hidden');
    }

    async function confirmReset() {
      const pw = document.getElementById('reset-password').value;
      if (!pw) {
        setText('reset-modal-msg', tAdmin('a_msg_enter_password'), true);
        return;
      }

      try {
        const res = await fetch('/api/admin/reset', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ admin_pin: adminPin, reset_password: pw }),
        });

        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_reset_failed'));

        setText(
          'reset-msg',
          adminLang() === 'ko'
            ? `초기화 완료: employees ${data.deleted_employees}, faces ${data.deleted_face_templates}, events ${data.deleted_time_events}`
            : `Reset complete: employees ${data.deleted_employees}, faces ${data.deleted_face_templates}, events ${data.deleted_time_events}`
        );
        closeResetModal();
        // Reset kiosk state and reload to start clean.
        recognized = null;
        renderRecognized();
        setTimeout(() => window.location.reload(), 400);
      } catch (err) {
        setText('reset-modal-msg', err.message, true);
      }
    }

	    async function init() {
	      try {
	        // Default language must be English.
	        try { uiLang = localStorage.getItem('tlj_lang') || 'en'; } catch (_) { uiLang = 'en'; }
		        if (uiLang !== 'ko' && uiLang !== 'es' && uiLang !== 'en') uiLang = 'en';
		        try { document.documentElement.setAttribute('data-lang', uiLang); } catch (_) {}
		        applyKioskI18n();
		        applyAdminI18n();
		        const sanitizePayrollEmail = () => {
	          const pe = document.getElementById('payroll-email-to');
	          if (!pe) return;
	          const cur = String(pe.value || '').trim();
	          // Kill stale values like "store-001" injected by browser form restore/autofill.
	          if (document.activeElement !== pe && cur && !cur.includes('@')) pe.value = '';

	          let saved = '';
	          try { saved = (localStorage.getItem('tlj_payroll_email_to') || '').trim(); } catch (_) { saved = ''; }
	          if (!pe.value && saved.includes('@')) pe.value = saved;
	        };

	        // Ensure payroll email input is a real email (avoid browser caching old store-id values).
	        sanitizePayrollEmail();
	        // Some browsers restore form state after load/BFCache; sanitize again shortly after.
	        setTimeout(sanitizePayrollEmail, 0);
	        setTimeout(sanitizePayrollEmail, 120);
	        // Chrome can re-inject restored form values slightly later; keep wiping non-email values
	        // for a short time, but never while the user is typing (focused).
	        {
	          const startedAt = Date.now();
	          const t = setInterval(() => {
	            if (Date.now() - startedAt > 3000) {
	              clearInterval(t);
	              return;
	            }
	            sanitizePayrollEmail();
	          }, 100);
	        }
	        window.addEventListener('pageshow', sanitizePayrollEmail);

	        const pe = document.getElementById('payroll-email-to');
	        if (pe) {
	          const persist = () => {
	            const cur = (pe.value || '').trim();
	            try {
	              if (cur.includes('@')) localStorage.setItem('tlj_payroll_email_to', cur);
	              else localStorage.removeItem('tlj_payroll_email_to');
	            } catch (_) {}
	          };
	          pe.addEventListener('change', persist);
	          pe.addEventListener('blur', persist);
	        }

	        // Admin idle timeout: if Admin is open and the user does nothing for 5 minutes,
	        // auto-return to the kiosk tab. Any activity resets the timer.
	        const markAdminActivity = () => {
	          const adminVisible = !document.getElementById('admin-panel')?.classList.contains('hidden');
	          if (!adminVisible) return;
	          resetAdminIdleTimer();
	        };
	        for (const evt of ['pointerdown', 'touchstart', 'keydown', 'input', 'wheel']) {
	          window.addEventListener(evt, markAdminActivity, { passive: true });
	        }
	        // Scroll events don't support passive option consistently across browsers.
	        window.addEventListener('scroll', markAdminActivity);

	        toggleActionButtons(false);
	        await startKiosk();

        // Allow Enter to verify admin PIN.
        const adminPinEl = document.getElementById('admin-pin');
        if (adminPinEl) {
          adminPinEl.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') verifyAdminPin();
          });
        }

        // Allow Enter to trigger admin query once authenticated.
        for (const id of ['query-q', 'query-start', 'query-end']) {
          const el = document.getElementById(id);
          if (!el) continue;
          el.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') queryEvents();
          });
        }

	        document.addEventListener('keydown', (e) => {
	          if (e.key === 'Escape') {
	            closeResetModal();
	            closePinModal();
	            closeEmployeeModal();
	            closeEmployeeEditModal();
	            closeEmployeeBulkModal();
	            closeFaceModal();
	          }
	        });

	        // iPad portrait: keep Employee Registration card height aligned with Dashboard.
	        let resizeTimer = null;
	        window.addEventListener('resize', () => {
	          if (resizeTimer) clearTimeout(resizeTimer);
	          resizeTimer = setTimeout(syncAdminEmployeeCardHeight, 80);
	        });
	        setTimeout(syncAdminEmployeeCardHeight, 120);

		      } catch (err) {
	        document.getElementById('scan-status').textContent = `${t('k_init_failed')}: ${err.message}`;
	      }
	    }

	    async function loadPayrollAutoEmailStatus() {
	      if (!adminPin) return;
	      try {
	        const res = await fetch(`/api/admin/payroll-auto-email/status?admin_pin=${encodeURIComponent(adminPin)}`);
	        const text = await res.text();
	        let data = {};
	        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
	        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_auto_status_failed'));

	        const enabledEl = document.getElementById('auto-payroll-enabled');
	        const emailEl = document.getElementById('auto-payroll-email');
	        if (enabledEl) enabledEl.checked = !!data.enabled;
        const catchupEl = document.getElementById('auto-payroll-catchup-once');
        if (catchupEl) catchupEl.checked = data.catchup_once !== false;
	        if (emailEl) {
	          const current = (data.to_email || '').trim();
	          if (current) emailEl.value = current;
	          else if (!emailEl.value) {
	            const base = (document.getElementById('payroll-email-to')?.value || '').trim();
	            // Only copy a real email (avoid old cached store-id values like "store-001").
	            if (base.includes('@')) emailEl.value = base;
	          }
	        }
	        const statusEl = document.getElementById('auto-payroll-status');
	        const last = data.last_sent_end ? String(data.last_sent_end) : (adminLang() === 'ko' ? '없음' : 'None');
	        const err = (data.last_error || '').trim();
	        if (statusEl) {
	          statusEl.textContent = adminLang() === 'ko'
            ? `설정: ${data.enabled ? 'ON' : 'OFF'} | 보정발송: ${data.catchup_once === false ? 'OFF' : 'ON'} | 마지막 전송(종료일): ${last}${err ? ' | 최근 오류: ' + err : ''}`
            : `Status: ${data.enabled ? 'ON' : 'OFF'} | Catch-up: ${data.catchup_once === false ? 'OFF' : 'ON'} | Last sent (end date): ${last}${err ? ' | Last error: ' + err : ''}`;
	        }
	      } catch (err) {
	        const statusEl = document.getElementById('auto-payroll-status');
	        if (statusEl) statusEl.textContent = '';
	        setText('auto-payroll-msg', err.message, true);
	      }
	    }

	    async function savePayrollAutoEmail() {
	      if (!adminPin) {
	        setText('auto-payroll-msg', tAdmin('a_msg_admin_required'), true);
	        return;
	      }
	      const enabled = !!document.getElementById('auto-payroll-enabled')?.checked;
	      const toEmail = (document.getElementById('auto-payroll-email')?.value || '').trim();
      const catchupOnce = !!document.getElementById('auto-payroll-catchup-once')?.checked;
	      if (enabled && !toEmail) {
	        setText('auto-payroll-msg', tAdmin('a_msg_auto_need_email'), true);
	        return;
	      }
	      try {
	        const res = await fetch('/api/admin/payroll-auto-email/config', {
	          method: 'POST',
	          headers: { 'Content-Type': 'application/json' },
	          body: JSON.stringify({ admin_pin: adminPin, enabled, to_email: toEmail || null, catchup_once: catchupOnce }),
	        });
	        const text = await res.text();
	        let data = {};
	        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
	        if (!res.ok || !data.ok) throw new Error(data.detail || text || tAdmin('a_msg_auto_save_failed'));
	        setText('auto-payroll-msg', tAdmin('a_msg_auto_saved'));
	        await loadPayrollAutoEmailStatus();
	      } catch (err) {
	        setText('auto-payroll-msg', err.message, true);
	      }
	    }

      // iPad/iOS Safari: prevent keyboard + backspace/delete from auto-scrolling the whole page.
      // Rule: while editing admin inputs, the page must not move unless the user scrolls manually.
      (function setupIOSScrollLock() {
        const isIOS = () => {
          try {
            return !!(window.CSS && CSS.supports && CSS.supports('-webkit-touch-callout: none')) &&
              /Apple/i.test(navigator.vendor || '') &&
              (navigator.maxTouchPoints || 0) > 1;
          } catch (_) {
            return false;
          }
        };
        if (!isIOS()) return;

        let locked = false;
        let savedY = 0;

        const isEditable = (el) => {
          if (!el || !el.tagName) return false;
          const tag = el.tagName.toLowerCase();
          return tag === 'input' || tag === 'textarea' || tag === 'select';
        };
        const inAdmin = (el) => {
          const admin = document.getElementById('admin-panel');
          return !!admin && admin.contains(el);
        };
        const shouldLock = (el) => isEditable(el) && inAdmin(el);

        const lock = () => {
          if (locked) return;
          savedY = window.scrollY || window.pageYOffset || 0;
          document.body.classList.add('ios-scroll-lock');
          document.body.style.top = `-${savedY}px`;
          locked = true;
        };
        const unlock = () => {
          if (!locked) return;
          document.body.classList.remove('ios-scroll-lock');
          document.body.style.top = '';
          window.scrollTo(0, savedY);
          locked = false;
        };

        // Lock as early as possible (before focus triggers Safari's scroll adjustments).
        document.addEventListener('touchstart', (e) => {
          const t = e.target;
          if (shouldLock(t)) lock();
        }, { passive: true, capture: true });
        document.addEventListener('focusin', (e) => {
          const t = e.target;
          if (shouldLock(t)) lock();
        }, true);
        document.addEventListener('focusout', () => {
          // If focus moves to another admin input, keep locked.
          setTimeout(() => {
            const a = document.activeElement;
            if (!shouldLock(a)) unlock();
          }, 50);
        }, true);
      })();

    window.addEventListener('load', init);
  </script>
