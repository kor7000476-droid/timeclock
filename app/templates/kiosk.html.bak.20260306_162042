      document.getElementById('lang-en')?.classList.toggle('active', uiLang === 'en');
      document.getElementById('lang-ko')?.classList.toggle('active', uiLang === 'ko');
      document.getElementById('lang-es')?.classList.toggle('active', uiLang === 'es');
