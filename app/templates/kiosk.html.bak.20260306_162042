	    async function detectFacePresence(videoId = 'camera') {
	      if (!modelsReady) return false;
	      const video = document.getElementById(videoId);
	      if (!video || !video.srcObject) return false;
	      try {
	        const det = await faceapi.detectSingleFace(
	          video,
	          new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.5 })
	        );
	        return !!det;
	      } catch (_) {
	        return false;
	      }
	    }

	    async function identifyFace() {
	      if (cooldown) return;
	      const now = Date.now();

	      // Lightweight face presence detection so we can clear stale names after prolonged no-face.
	      const present = await detectFacePresence('camera');
	      if (present) {
	        lastFaceSeenAt = now;
	        idleWaiting = false;
	      } else {
	        // If a user was recognized, allow a short grace period to press a button after stepping away.
	        if (recognized) {
	          const dt = now - lastFaceSeenAt;
	          if (dt < ACTION_GRACE_MS) {
	            document.getElementById('scan-status').textContent = t('k_face_lost_grace');
	            return;
	          }
	          // Face is gone beyond grace: reset to waiting for the next user.
	          idleWaiting = true;
	          recognized = null;
	          renderRecognized();
	          document.getElementById('scan-status').textContent = t('k_waiting');
	          return;
	        }

	        if (now - lastFaceSeenAt >= 30000) {
	          // 30s idle: show waiting.
	          idleWaiting = true;
	          recognized = null;
	          renderRecognized();
	          document.getElementById('scan-status').textContent = t('k_waiting');
	          return;
	        }
	      }

	      const result = present ? await detectDescriptor('camera') : null;
	      if (!result) {
	        // Descriptor can fail intermittently; keep the last recognized during grace.
	        if (!recognized) renderRecognized();
	        document.getElementById('scan-status').textContent = idleWaiting ? t('k_waiting') : t('k_scan_align');
	        return;
	      }

      try {
        const res = await fetch('/api/identify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ embedding: result.descriptor, threshold: 0.50 }),
        });
        const data = await res.json();

		        if (data.matched) {
		          recognized = {
		            employee_code: data.employee_code,
		            employee_name: data.employee_name,
		            confidence: data.confidence,
		            distance: data.distance,
		            status: data.status || null,
		            allowed_events: Array.isArray(data.allowed_events) ? data.allowed_events : null,
		          };
		          recognizedAt = Date.now();
		          lastFaceSeenAt = recognizedAt;
		          document.getElementById('scan-status').textContent = t('k_verified_press');
		        } else {
          recognized = null;
          document.getElementById('scan-status').textContent = (data && data.reason === 'AMBIGUOUS')
            ? t('k_ambiguous')
            : t('k_unknown_face');
        }
	        renderRecognized();
	      } catch (err) {
	        // Avoid mixing raw browser/JS error strings (often English) with the selected kiosk language.
	        // Keep detail in console for debugging.
	        console.error('identifyFace error', err);
	        document.getElementById('scan-status').textContent = t('k_api_error');
	      }
	    }

	    function renderRecognized() {
	      const nameEl = document.getElementById('recognized-name');
	      const metaEl = document.getElementById('recognized-meta');

	      if (!recognized) {
	        nameEl.textContent = idleWaiting ? t('k_waiting') : t('k_not_recognized');
	        metaEl.textContent = idleWaiting ? '' : t('k_recognized_hint');
	        toggleActionButtons(false);
	        return;
	      }

	      nameEl.textContent = recognized.employee_name;
	      const st = recognized.status ? ` | ${recognized.status}` : '';
	      metaEl.textContent = `${recognized.employee_code} | confidence ${recognized.confidence} | distance ${recognized.distance}${st}`;
	      // Enable only valid actions based on server state.
	      if (recognized.allowed_events && recognized.allowed_events.length) setAllowedActions(recognized.allowed_events);
	      else toggleActionButtons(true);
	    }

