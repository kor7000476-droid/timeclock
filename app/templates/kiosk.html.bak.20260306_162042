	    // Simple "ding-dong" success chime (no external audio file).
	    // Plays best on user interaction (e.g., button press) due to iOS autoplay restrictions.
	    let _audioCtx = null;
	    function playDingDong() {
	      try {
	        const Ctx = window.AudioContext || window.webkitAudioContext;
	        if (!Ctx) return;
	        if (!_audioCtx) _audioCtx = new Ctx();
	        if (_audioCtx.state === 'suspended') {
	          // On iOS this typically resumes on the same click/tap.
	          _audioCtx.resume().catch(() => {});
	        }

	        const now = _audioCtx.currentTime;
	        const master = _audioCtx.createGain();
	        master.gain.setValueAtTime(0.0001, now);
	        master.gain.exponentialRampToValueAtTime(0.12, now + 0.01);
	        master.gain.exponentialRampToValueAtTime(0.0001, now + 0.55);
	        master.connect(_audioCtx.destination);

	        const makeTone = (freq, t0, dur) => {
	          const o = _audioCtx.createOscillator();
	          const g = _audioCtx.createGain();
	          o.type = 'sine';
	          o.frequency.setValueAtTime(freq, t0);
	          g.gain.setValueAtTime(0.0001, t0);
	          g.gain.exponentialRampToValueAtTime(1.0, t0 + 0.01);
	          g.gain.exponentialRampToValueAtTime(0.0001, t0 + dur);
	          o.connect(g);
	          g.connect(master);
	          o.start(t0);
	          o.stop(t0 + dur + 0.02);
	        };

	        // Two-step chime: "ding" then "dong"
	        makeTone(880, now, 0.18);
	        makeTone(659.25, now + 0.18, 0.22);
	      } catch (_) {
	        // ignore
	      }
	    }

