    async function saveEmployeeEditModal() {
      if (!adminPin || !employeeEditId) return;
      const nameEl = document.getElementById('emp-edit-name');
      const adpEl = document.getElementById('emp-edit-adp');
      const name = (nameEl?.value || '').trim().slice(0, 15);
      const adp = (adpEl?.value || '').trim().slice(0, 8);
      if (nameEl) nameEl.value = name;
      if (adpEl) adpEl.value = adp;
      const title = document.getElementById('emp-edit-title')?.value || 'STAFF';
      const group = document.getElementById('emp-edit-group')?.value || 'FRONT';
      const active = !!document.getElementById('emp-edit-active')?.checked;
      const hireDate = document.getElementById('emp-edit-hire')?.value || '';
      const termDate = document.getElementById('emp-edit-term')?.value || '';

      if (!name || !hireDate) {
        setText('employee-edit-msg', tAdmin('a_msg_name_hire_required'), true);
        return;
      }

      try {
        const res = await fetch(`/api/admin/employees/${encodeURIComponent(employeeEditId)}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            admin_pin: adminPin,
            name,
            adp_mapping_code: adp || null,
            hire_date: hireDate,
            termination_date: termDate || null,
            title,
            work_group: group,
            is_active: active,
          }),
        });
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_employee_update_failed'));
        setText('employee-edit-msg', tAdmin('a_msg_saved'));
        await loadAdminEmployees();
      } catch (err) {
        setText('employee-edit-msg', err.message, true);
      }
    }

