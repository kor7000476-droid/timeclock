	    async function captureFaceSample() {
	      try {
	        if (faceAutoCloseTimer) {
	          clearTimeout(faceAutoCloseTimer);
	          faceAutoCloseTimer = null;
	        }
	        if (faceSaving) {
	          setText('face-msg', tAdmin('a_msg_face_saving'), true);
	          return;
	        }
	        if (faceSamples.length >= FACE_SAMPLE_TARGET) {
	          // Auto-save may have failed or been delayed; allow a retry by pressing capture.
	          setText('face-msg', tAdmin('a_msg_face_already_captured'), true);
	          await saveFaceSamples(true);
	          return;
	        }
	        syncAdminCamera();
	        const result = await detectDescriptor('admin-camera');
	        if (!result) throw new Error(tAdmin('a_msg_face_not_detected'));
	        if (result.score < 0.75) throw new Error(tAdmin('a_msg_face_low_quality'));

        const last = faceSamples.length > 0 ? faceSamples[faceSamples.length - 1] : null;
        if (last && descriptorDistance(last, result.descriptor) < 0.02) {
          throw new Error(tAdmin('a_msg_face_too_similar'));
        }

	        faceSamples.push(result.descriptor);
	        document.getElementById('face-sample-count').textContent = adminSampleCountText(faceSamples.length);
	        setText(
	          'face-msg',
	          adminLang() === 'ko'
	            ? `샘플 캡처 완료 (${faceSamples.length}) / score ${result.score.toFixed(2)}`
	            : `Sample captured (${faceSamples.length}) / score ${result.score.toFixed(2)}`
	        );

	        if (faceSamples.length >= FACE_SAMPLE_TARGET) {
	          // Auto-save after 5 samples.
	          await saveFaceSamples(true);
	        }
	      } catch (err) {
	        setText('face-msg', err.message, true);
	      }
	    }

	    async function saveFaceSamples(auto = false, force = false) {
	      const employeeCode = document.getElementById('face-employee').value;
	      if (!employeeCode) {
	        setText('face-msg', tAdmin('a_msg_select_employee'), true);
	        return;
	      }
	      if (faceSamples.length < 3) {
	        // User attempted to save <3 samples: force restart from scratch.
	        faceSamples = [];
	        document.getElementById('face-sample-count').textContent = adminSampleCountText(0);
	        setText('face-msg', tAdmin('a_msg_face_need_3'), true);
	        return;
	      }

	      try {
	        if (faceAutoCloseTimer) {
	          clearTimeout(faceAutoCloseTimer);
	          faceAutoCloseTimer = null;
	        }
	        faceSaving = true;
	        setText('face-msg', auto ? tAdmin('a_msg_face_auto_saving') : tAdmin('a_msg_saving'));
	        const controller = (typeof AbortController !== 'undefined') ? new AbortController() : null;
	        const timer = controller ? setTimeout(() => controller.abort(), 15000) : null;
	        const res = await fetch('/api/faces/register', {
	          method: 'POST',
	          headers: { 'Content-Type': 'application/json' },
	          signal: controller ? controller.signal : undefined,
	          body: JSON.stringify({
	            employee_code: employeeCode,
	            embeddings: faceSamples,
	            admin_pin: adminPin,
	            replace_existing: true,
	            force: !!force,
	          }),
	        });
	        if (timer) clearTimeout(timer);
	        const text = await res.text();
	        let data = {};
	        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = { detail: text }; }
	        if (!res.ok) {
	          const detail = data && data.detail;
	          if (res.status === 409 && detail && typeof detail === 'object' && detail.type === 'FACE_DUPLICATE') {
	            const dupCode = detail.duplicate_employee_code || '';
	            const dupName = detail.duplicate_employee_name || '';
	            const dist = detail.distance != null ? String(detail.distance) : '';
	            const extra =
	              detail.duplicate_is_active === false || detail.duplicate_termination_date
	                ? (adminLang() === 'ko'
	                    ? ` (퇴사/비활성 가능: ${detail.duplicate_termination_date || 'N/A'})`
	                    : ` (may be terminated/inactive: ${detail.duplicate_termination_date || 'N/A'})`)
	                : '';
	            const msg =
	              adminLang() === 'ko'
	                ? `중복 얼굴이 감지되었습니다.\n이미 ${dupName} (${dupCode})에 등록된 얼굴과 유사합니다. distance=${dist}${extra}\n그래도 현재 직원(${employeeCode})으로 등록을 진행할까요?`
	                : `Duplicate face detected.\nThis face looks similar to ${dupName} (${dupCode}). distance=${dist}${extra}\nDo you want to continue enrolling for (${employeeCode}) anyway?`;
	            const ok = window.confirm(msg);
	            if (ok) {
	              await saveFaceSamples(auto, true);
	              return;
	            }
	            // Cancel: reset samples so the user can recapture (otherwise they'd be stuck at 5/5).
	            faceSamples = [];
	            document.getElementById('face-sample-count').textContent = adminSampleCountText(0);
	            setText('face-msg', adminLang() === 'ko' ? '중복 등록이 취소되었습니다. 샘플을 초기화했습니다. 다시 캡처하세요.' : 'Duplicate enrollment canceled. Samples were cleared. Please recapture.', true);
	            return;
	          }
	          const errMsg = typeof detail === 'string' ? detail : (detail ? JSON.stringify(detail) : '');
	          throw new Error(errMsg || tAdmin('a_msg_face_register_failed'));
	        }

	        setText('face-msg', adminFaceSavedText(employeeCode, data.template_count));
	        faceSamples = [];
	        document.getElementById('face-sample-count').textContent = adminSampleCountText(0);
	        await loadAdminEmployees();
	        await loadAdminOverview();
	        // Success notify + auto-close quickly.
	        showTransientPopup(
	          tAdmin('a_alert_face_ok'),
	          '',
	          2000
	        );
	        scheduleFaceModalAutoClose(2000);
	      } catch (err) {
	        const isAbort = err && (err.name === 'AbortError');
	        if (isAbort) {
	          setText('face-msg', adminLang() === 'ko' ? '저장 시간이 초과되었습니다. 네트워크/서버 상태를 확인한 뒤 “얼굴 등록 저장”을 다시 눌러주세요.' : 'Save timed out. Please check network/server and press “Save Face” again.', true);
	        } else {
	        setText('face-msg', err.message, true);
	        }
	      } finally {
	        faceSaving = false;
	      }
	    }

