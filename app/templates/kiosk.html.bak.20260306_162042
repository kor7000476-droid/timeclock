      const groupEl = document.getElementById(`emp-group-${id}`);
      const titleEl = document.getElementById(`emp-title-${id}`);
      const activeEl = document.getElementById(`emp-active-${id}`);
      if (!nameEl || !hireEl || !termEl || !groupEl || !titleEl || !activeEl) return null;

      const name = String(nameEl.value || '').trim().slice(0, 15);
      const adp = String(adpEl?.value || '').trim().slice(0, 8);
      const hireDate = String(hireEl.value || '');
      const termDateRaw = String(termEl.value || '');
      const title = String(titleEl.value || 'STAFF').toUpperCase();
      const workGroup = String(groupEl.value || 'FRONT').toUpperCase();
      const isActive = !!activeEl.checked;

      nameEl.value = name;
      if (adpEl) adpEl.value = adp;

      return {
        id,
        name,
        adp_mapping_code: adp || null,
        hire_date: hireDate,
        termination_date: termDateRaw || null,
        title,
        work_group: workGroup,
        is_active: isActive,
      };
    }

    function isEmployeeRowDirty(employeeId, baseRow = null) {
      const draft = getEmployeeRowDraft(employeeId);
      if (!draft) return false;
      const base = baseRow || adminEmployees.find((row) => String(row.id) === String(employeeId));
      if (!base) return false;
      return (
        draft.name !== String(base.name || '') ||
        (draft.adp_mapping_code || null) !== (base.adp_mapping_code || null) ||
        draft.hire_date !== String(base.hire_date || '') ||
        (draft.termination_date || null) !== (base.termination_date || null) ||
        draft.title !== String(base.title || 'STAFF').toUpperCase() ||
        draft.work_group !== String(base.work_group || 'FRONT').toUpperCase() ||
        draft.is_active !== !!base.is_active
      );
    }

    function collectDirtyEmployeeIds() {
      const inputs = document.querySelectorAll('#employees-manage-body input[id^="emp-name-"]');
      const dirtyIds = [];
      for (const input of inputs) {
        const id = String(input.id || '').replace('emp-name-', '');
        if (!id) continue;
        if (isEmployeeRowDirty(id)) dirtyIds.push(id);
      }
      return dirtyIds;
    }

