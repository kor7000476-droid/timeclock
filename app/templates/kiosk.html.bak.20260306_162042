	      const dash = document.getElementById('admin-dashboard-card');
	      const emp = document.getElementById('employee-register-card');
	      const payroll = document.getElementById('payroll-csv-card');
	      if (!dash || !emp || !payroll) return;

	      const isPortraitNarrow = (() => {
	        try {
	          return window.matchMedia &&
	            window.matchMedia('(max-width: 900px) and (orientation: portrait)').matches;
	        } catch (_) {
	          return false;
	        }
	      })();

	      // Only sync heights when admin content is visible on iPad portrait.
	      const adminContentVisible = !document.getElementById('admin-content')?.classList.contains('hidden');
	      if (!isPortraitNarrow || !adminContentVisible) {
	        emp.style.height = '';
	        payroll.style.height = '';
	        return;
	      }

	      const h = Math.round(dash.getBoundingClientRect().height || 0);
	      if (h > 0) {
	        emp.style.height = `${h}px`;
      }
      // Payroll CSV card should grow naturally so iPad can show all controls without inner scroll.
      payroll.style.height = '';
	    }

