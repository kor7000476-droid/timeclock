    function applyKioskI18n() {
      // Only translate Kiosk panel.
      for (const el of document.querySelectorAll('#kiosk-panel [data-i18n]')) {
        const key = el.getAttribute('data-i18n');
        if (!key) continue;
        el.textContent = t(key);
