          <td><div class="manage-date-wrap"><input class="mini-input manage-date-input" id="emp-hire-${row.id}" type="date" value="${row.hire_date || ''}" ondblclick="openManageDatePicker('${row.id}', 'hire')" onchange="syncManageDateDisplay('${row.id}', 'hire')" style="width:104px;" /><span class="manage-date-label" id="emp-hire-label-${row.id}">${formatManageDateShort(row.hire_date)}</span></div></td>
          <td><div class="manage-date-wrap"><input class="mini-input manage-date-input" id="emp-term-${row.id}" type="date" value="${row.termination_date || ''}" ondblclick="openManageDatePicker('${row.id}', 'term')" onchange="syncManageDateDisplay('${row.id}', 'term')" style="width:104px;" /><span class="manage-date-label" id="emp-term-label-${row.id}">${formatManageDateShort(row.termination_date)}</span></div></td>
          <td><select class="mini-select" id="emp-group-${row.id}" style="width:74px;">${groupOptions(row.work_group || 'FRONT')}</select></td>
          <td><select class="mini-select" id="emp-title-${row.id}" style="width:74px;">${titleOptions(row.title || 'STAFF')}</select></td>
          <td style="text-align:center;"><input type="checkbox" id="emp-active-${row.id}" ${row.is_active ? 'checked' : ''} /></td>
          <td class="emp-sticky face-col"><button class="mini-btn face-enroll-btn${faceDone ? ' done' : ''}" onclick="openFaceModal('${row.employee_code}')">${faceLabel}</button></td>
          <td class="emp-sticky save-col"><button class="admin-btn mini-btn" onclick="saveEmployee('${row.id}')">${tAdmin('a_btn_save')}</button></td>
