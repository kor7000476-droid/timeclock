    async function refreshOfflineFaceCacheFromServer() {
      try {
        const res = await fetch('/api/offline/face-cache', { cache: 'no-store' });
        const text = await res.text();
        const data = safeJsonParse(text, {});
        if (!res.ok) throw new Error(data.detail || text || 'face cache fetch failed');
        setOfflineFaceCache(data);
        await saveOfflineFaceCacheSnapshot(data);
        offlineFaceLastRefreshMs = Date.now();
        return true;
      } catch (_) {
        return false;
      }
    }

    async function ensureOfflineFaceCacheReady() {
      if (offlineFaceCache.length > 0) return true;
      try {
        const snapshot = await loadOfflineFaceCacheSnapshot();
        if (snapshot) {
          setOfflineFaceCache(snapshot);
          if (offlineFaceCache.length > 0) {
            offlineFaceLastRefreshMs = Date.now();
            return true;
          }
        }
      } catch (_) {}
      return offlineFaceCache.length > 0;
    }

    async function warmOfflineFaceCache() {
      try {
        const snapshot = await loadOfflineFaceCacheSnapshot();
        if (snapshot) {
          setOfflineFaceCache(snapshot);
          if (offlineFaceCache.length > 0) offlineFaceLastRefreshMs = Date.now();
        }
      } catch (_) {}
      if (!offlineMode) await refreshOfflineFaceCacheFromServer();
    }

    function distanceEuclidean(a, b) {
      if (!Array.isArray(a) || !Array.isArray(b) || a.length !== b.length) return Number.POSITIVE_INFINITY;
      let sum = 0;
      for (let index = 0; index < a.length; index += 1) {
        const diff = Number(a[index]) - Number(b[index]);
        sum += diff * diff;
      }
      return Math.sqrt(sum);
    }

    function identifyFaceOffline(descriptor) {
      if (!Array.isArray(descriptor) || descriptor.length < 32 || offlineFaceCache.length === 0) {
        return {
          matched: false,
          employee_code: null,
          employee_name: null,
          confidence: 0,
          distance: null,
          reason: 'NO_CACHE',
          status: null,
          allowed_events: null,
        };
      }
      let best = null;
      let second = null;
      for (const employee of offlineFaceCache) {
        const embeds = Array.isArray(employee.embeddings) ? employee.embeddings : [];
        for (const candidate of embeds) {
          const dist = distanceEuclidean(descriptor, candidate);
          if (!Number.isFinite(dist)) continue;
          const row = { employee_code: employee.employee_code, employee_name: employee.employee_name, distance: dist };
          if (!best || dist < best.distance) {
            second = best;
            best = row;
          } else if (!second || dist < second.distance) {
            second = row;
          }
        }
      }
      if (!best) {
        return {
          matched: false,
          employee_code: null,
          employee_name: null,
          confidence: 0,
          distance: null,
          reason: 'NO_MATCH',
          status: null,
          allowed_events: null,
        };
      }
      if (best.distance > offlineFaceThreshold) {
        return {
          matched: false,
          employee_code: null,
          employee_name: null,
          confidence: Math.max(0, Number((1 - best.distance).toFixed(4))),
          distance: Number(best.distance.toFixed(4)),
          reason: 'NO_MATCH',
          status: null,
          allowed_events: null,
        };
      }
      if (second && (second.distance - best.distance) < OFFLINE_AMBIGUOUS_MARGIN) {
        return {
          matched: false,
          employee_code: null,
          employee_name: null,
          confidence: 0,
          distance: Number(best.distance.toFixed(4)),
          reason: 'AMBIGUOUS',
          status: null,
          allowed_events: null,
        };
      }
      const status = String(localStatusByEmployee[best.employee_code] || '').trim() || null;
      const allowedEvents = getLocalAllowedEvents(best.employee_code);
      return {
        matched: true,
        employee_code: best.employee_code,
        employee_name: best.employee_name,
        confidence: Math.max(0, Number((1 - best.distance).toFixed(4))),
        distance: Number(best.distance.toFixed(4)),
        reason: null,
        status,
        allowed_events: allowedEvents,
      };
    }

    async function runOfflineHealthLoop() {
      if (offlineSyncTimer) clearInterval(offlineSyncTimer);
      offlineSyncTimer = setInterval(async () => {
        const ok = await checkApiHealthOnline();
        await setOfflineMode(!ok);
        if (ok) {
          await syncQueuedEvents();
          if ((Date.now() - offlineFaceLastRefreshMs) >= OFFLINE_FACE_REFRESH_INTERVAL_MS) {
            await refreshOfflineFaceCacheFromServer();
          }
        }
      }, OFFLINE_SYNC_INTERVAL_MS);
    }

    async function initializeOfflineSubsystem() {
      loadLocalStatusMap();
      try { await openOfflineDb(); } catch (_) {}
      await loadOfflineQueueCount();
      const healthy = await checkApiHealthOnline();
      await setOfflineMode(!healthy);
      await warmOfflineFaceCache();
      if (healthy) await syncQueuedEvents();
      await runOfflineHealthLoop();
      window.addEventListener('online', async () => {
        await setOfflineMode(false);
        await syncQueuedEvents();
        await refreshOfflineFaceCacheFromServer();
      });
      window.addEventListener('offline', async () => {
        await setOfflineMode(true);
      });
    }

