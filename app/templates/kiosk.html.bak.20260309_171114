    async function queryEvents(page = 1) {
      if (!adminPin) {
        setText('query-msg', tAdmin('a_msg_admin_required'), true);
        setText('query-modal-msg', tAdmin('a_msg_admin_required'), true);
        return;
      }

      const backdrop = document.getElementById('query-modal-backdrop');
      if (backdrop?.classList.contains('hidden')) openQueryModal();

      const filters = readQueryFilters('modal');
      const scope = (filters.scope || 'ALL').toUpperCase();
      const eventFilter = (filters.event_filter || 'ALL').toUpperCase();
      const q = (filters.q || '').trim();
      const start = filters.start_date || '';
      const end = filters.end_date || '';
      syncQueryMainFromModal();
      saveQueryFilters();

      if (!start || !end) {
        setText('query-modal-msg', tAdmin('a_msg_need_query_dates'), true);
        setText('query-msg', tAdmin('a_msg_need_query_dates'), true);
        setQueryVisibility(false);
        return;
      }
      if (scope !== 'ALL' && !q) {
        setText('query-modal-msg', tAdmin('a_msg_need_query_keyword'), true);
        setText('query-msg', tAdmin('a_msg_need_query_keyword'), true);
        setQueryVisibility(false);
        return;
      }

      setText('query-modal-msg', tAdmin('a_msg_searching'));
      setText('query-msg', tAdmin('a_msg_searching'));
      setQueryVisibility(false);

      const safePage = Math.max(1, Number(page || 1));
      const url = `/api/admin/events/query?admin_pin=${encodeURIComponent(adminPin)}&start_date=${encodeURIComponent(start)}&end_date=${encodeURIComponent(end)}&scope=${encodeURIComponent(scope)}&event_filter=${encodeURIComponent(eventFilter)}&q=${encodeURIComponent(q)}&page=${encodeURIComponent(safePage)}&page_size=${encodeURIComponent(QUERY_PAGE_SIZE)}`;
      try {
        const res = await fetch(url);
        const text = await res.text();
        let data = {};
        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
        if (!res.ok) throw new Error(data.detail || text || tAdmin('a_msg_query_failed'));

        const summaries = data.summaries || [];
        const events = data.events || [];
        const matched = Number(data.matched_employees || 0);
        const totalEvents = Number(data.total_events || 0);
        queryCurrentPage = Math.max(1, Number(data.page || safePage));
        queryTotalPages = Math.max(0, Number(data.total_pages || 0));
        queryLastTotalEvents = totalEvents;

        if (matched === 0 || totalEvents === 0) {
          setText('query-modal-msg', tAdmin('a_msg_no_results'), true);
          setText('query-msg', tAdmin('a_msg_no_results'), true);
          setQueryVisibility(false);
          updateQueryPager();
          return;
        }

        let totalWork = 0;
        let totalBreak = 0;
        const dayMap = new Map();
        for (const s of summaries) {
          totalWork += Number(s.total_work_minutes || 0);
          totalBreak += Number(s.total_break_minutes || 0);
          for (const d of (s.days || [])) {
            const key = d.work_date;
            const cur = dayMap.get(key) || { work: 0, break: 0 };
            cur.work += Number(d.work_minutes || 0);
            cur.break += Number(d.break_minutes || 0);
            dayMap.set(key, cur);
          }
        }

        const dayKeys = Array.from(dayMap.keys()).sort();
        const summaryEl = document.getElementById('query-modal-summary');

        const L = adminLang() === 'ko'
          ? {
              employees: '직원',
              period: '기간',
              period_total: '기간 합계',
              work: '근무',
              break: '브레이크',
              date: '일자',
              flags: '플래그',
              total_events: '전체 이벤트',
              scope: '조회대상',
              type: '이벤트유형',
            }
          : {
              employees: 'Employees',
              period: 'Period',
              period_total: 'Period Total',
              work: 'Work',
              break: 'Break',
              date: 'Date',
              flags: 'Flags',
              total_events: 'Total Events',
              scope: 'Scope',
              type: 'Type',
            };

        const scopeLabelMap = adminLang() === 'ko'
          ? { ALL: '전체', EMPLOYEE_CODE: '사번별', EMPLOYEE_NAME: '이름별' }
          : { ALL: 'All', EMPLOYEE_CODE: 'By code', EMPLOYEE_NAME: 'By name' };
        const typeLabelMap = adminLang() === 'ko'
          ? { ALL: '전체(혼합)', CLOCK: '출/퇴근', BREAK: '브레이크' }
          : { ALL: 'All (mixed)', CLOCK: 'Clock in/out', BREAK: 'Break in/out' };

        let html = '';
        html += `<div class="summary-line"><span class="pill">${L.employees} ${matched}</span><span class="pill">${L.total_events} ${totalEvents}</span><span class="pill">${L.period} ${start} 00:00:00 ~ ${end} 23:59:59 (ET)</span></div>`;
        html += `<div class="summary-line" style="margin-top:6px;"><span class="pill">${L.scope} ${scopeLabelMap[scope] || scope}</span><span class="pill">${L.type} ${typeLabelMap[eventFilter] || eventFilter}</span></div>`;
        html += `<div class="summary-line" style="margin-top:6px;"><div><b>${L.period_total}</b> ${L.work} ${minutesToHours(totalWork)} (${fmtMinutes(totalWork)})</div><div><b>${L.break}</b> ${minutesToHours(totalBreak)} (${fmtMinutes(totalBreak)})</div></div>`;

        html += `<div style="margin-top:8px; max-height:220px; overflow:auto;">`;
        html += `<table class="tight"><thead><tr><th>${L.date}</th><th>${L.work}</th><th>${L.break}</th></tr></thead><tbody>`;
        for (const k of dayKeys) {
          const v = dayMap.get(k);
          html += `<tr><td>${k}</td><td>${minutesToHours(v.work)} (${fmtMinutes(v.work)})</td><td>${minutesToHours(v.break)} (${fmtMinutes(v.break)})</td></tr>`;
        }
        html += `</tbody></table></div>`;

        for (const s of summaries) {
          const title = s.title || 'STAFF';
          html += `<details class="emp-summary">`;
          html += `<summary><span class="summary-line"><span>${s.employee_name} (${s.employee_code})</span><span class="pill">${title}</span><span class="pill">${L.work} ${minutesToHours(s.total_work_minutes)} </span><span class="pill">${L.break} ${minutesToHours(s.total_break_minutes)}</span></span></summary>`;
          html += `<div style="margin-top:8px; max-height:220px; overflow:auto;">`;
          html += `<table class="tight"><thead><tr><th>${L.date}</th><th>${L.work}</th><th>${L.break}</th><th>${L.flags}</th></tr></thead><tbody>`;
          for (const d of (s.days || [])) {
            const flags = (d.flags || []).join(', ');
            html += `<tr><td>${d.work_date}</td><td>${minutesToHours(d.work_minutes)} (${fmtMinutes(d.work_minutes)})</td><td>${minutesToHours(d.break_minutes)} (${fmtMinutes(d.break_minutes)})</td><td>${flags}</td></tr>`;
          }
          html += `</tbody></table></div>`;
          html += `</details>`;
        }

        if (summaryEl) summaryEl.innerHTML = html;

        const tbody = document.getElementById('query-modal-events-body');
        if (tbody) {
          tbody.innerHTML = '';
          for (const row of events) {
            const tr = document.createElement('tr');
            const ts = row.ts_et || utcIsoToLocal(row.ts_utc);
            tr.innerHTML = `<td>${ts}</td><td>${row.employee_code}</td><td>${row.employee_name}</td><td>${row.title || ''}</td><td>${row.event_type}</td><td>${row.method}</td>`;
            tbody.appendChild(tr);
          }
        }

        updateQueryPager();
        setText(
          'query-modal-msg',
          adminLang() === 'ko'
            ? `조회 완료: 직원 ${matched}명, 이벤트 ${totalEvents}건 (페이지 ${queryCurrentPage}/${Math.max(1, queryTotalPages || 1)})`
            : `Done: employees ${matched}, events ${totalEvents} (page ${queryCurrentPage}/${Math.max(1, queryTotalPages || 1)})`
        );
        setLocalizedStatus('query-msg', 'a_msg_query_popup_hint');
        setQueryVisibility(true);
      } catch (err) {
        setText('query-modal-msg', err.message, true);
        setText('query-msg', err.message, true);
        setQueryVisibility(false);
      }
    }

