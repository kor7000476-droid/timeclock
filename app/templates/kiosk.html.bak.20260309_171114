      if (!Number.isFinite(delta) || delta === 0) return;
      const nextPage = Math.max(1, Math.min(queryTotalPages || 1, queryCurrentPage + delta));
      if (nextPage === queryCurrentPage) return;
      queryEvents(nextPage);
