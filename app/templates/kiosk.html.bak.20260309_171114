    function minutesToHours(mins) {
      const m = Number(mins || 0);
      const h = m / 60.0;
      return `${h.toFixed(2)}h`;
    }

    function fmtMinutes(mins) {
      const m = Number(mins || 0);
      const h = Math.floor(m / 60);
      const mm = m % 60;
      if (h <= 0) return `${mm}m`;
      return `${h}h ${mm}m`;
    }

    function utcIsoToLocal(iso) {
      if (!iso) return '';
      let s = String(iso);
      if (!s.endsWith('Z') && !s.includes('+')) s += 'Z';
      const d = new Date(s);
      if (Number.isNaN(d.getTime())) return String(iso);
      return d.toLocaleString();
    }

    const QUERY_PAGE_SIZE = 30;
    const QUERY_FILTERS_KEY = 'timeclock_admin_event_query_filters_v2';
    let queryCurrentPage = 1;
    let queryTotalPages = 0;
    let queryLastTotalEvents = 0;

    function setQueryVisibility(hasData) {
      const sum = document.getElementById('query-modal-summary');
      const wrap = document.getElementById('query-modal-events-wrap');
      const pager = document.getElementById('query-modal-pager');
      if (!sum || !wrap || !pager) return;
      if (hasData) {
        sum.classList.remove('hidden');
        wrap.classList.remove('hidden');
        pager.classList.remove('hidden');
      } else {
