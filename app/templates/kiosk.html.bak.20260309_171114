    function setOfflineFaceCache(snapshot) {
      const list = Array.isArray(snapshot?.employees) ? snapshot.employees : [];
      offlineFaceCache = list.map((row) => ({
        employee_code: String(row.employee_code || ''),
        employee_name: String(row.employee_name || ''),
        embeddings: Array.isArray(row.embeddings) ? row.embeddings : [],
      })).filter((row) => row.employee_code && row.embeddings.length > 0);
      const threshold = Number(snapshot?.offline_threshold);
      if (Number.isFinite(threshold) && threshold > 0) {
        offlineFaceThreshold = threshold;
      }
