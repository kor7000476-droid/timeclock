	    function descriptorDistance(v1, v2) {
      if (!v1 || !v2 || v1.length !== v2.length) return 1;
      let sum = 0;
      for (let i = 0; i < v1.length; i += 1) {
        const diff = v1[i] - v2[i];
        sum += diff * diff;
      }
      return Math.sqrt(sum);
    }

