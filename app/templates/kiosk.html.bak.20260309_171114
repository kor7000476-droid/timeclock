	    async function submitEvent(eventType) {
      if (!recognized) {
        setText('event-toast', t('k_need_face'), true);
        return;
      }
	      const refTs = Math.max(Number(lastFaceSeenAt) || 0, Number(recognizedAt) || 0);
	      if (Date.now() - refTs >= ACTION_GRACE_MS) {
	        // Prevent actions after the face has been absent too long (avoid wrong-person taps).
	        recognized = null;
	        idleWaiting = true;
	        renderRecognized();
	        setText('event-toast', t('k_face_timeout'), true);
	        return;
	      }
      if (cooldown) {
        setText('event-toast', t('k_cooldown'), true);
        return;
      }

      const employeeCode = String(recognized.employee_code || '');
      const employeeName = String(recognized.employee_name || '');
      const payload = {
        employee_code: employeeCode,
        event_type: eventType,
        ts_utc: utcNaiveIsoNow(),
        event_uuid: generateEventUuid(),
        method: 'FACE',
        confidence: recognized.confidence,
        device_id: deviceId,
      };

      const finishSuccess = (offlineSaved) => {
        applyLocalEventStatus(employeeCode, eventType);
        const labelKey = `k_evt_${eventType}`;
        const suffix = offlineSaved ? ` · ${t('k_offline_saved')}` : '';
        setText('event-toast', `${employeeName} ${t(labelKey)} ${t('k_done')}${suffix}`);
        showGoodJobPopup();
        cooldown = true;
        toggleActionButtons(false);
        setTimeout(() => {
          cooldown = false;
          recognized = null;
          renderRecognized();
        }, 500);
      };

      try {
        if (!offlineMode && offlineQueueCount > 0) {
          await syncQueuedEvents();
        }

        if (offlineMode || offlineQueueCount > 0) {
          await queueOfflineEvent(payload);
          finishSuccess(true);
          return;
        }

        const sent = await postEventOnline(payload);
        if (sent.ok) {
          finishSuccess(false);
          return;
        }

        if (sent.retriable) {
          await setOfflineMode(true);
          await queueOfflineEvent(payload);
          finishSuccess(true);
          return;
        }

        throw new Error(sent.error || t('k_event_failed'));
      } catch (err) {
        setText('event-toast', err.message, true);
      }
    }

