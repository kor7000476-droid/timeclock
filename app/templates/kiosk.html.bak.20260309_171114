    function readQueryFilters(source = 'modal') {
      const prefix = source === 'main' ? '' : 'modal-';
      const scope = (document.getElementById(`query-${prefix}scope`)?.value || 'ALL').toUpperCase();
      const eventFilter = (document.getElementById(`query-${prefix}event-filter`)?.value || 'ALL').toUpperCase();
      const q = (document.getElementById(`query-${prefix}q`)?.value || '').trim();
      const start = document.getElementById(`query-${prefix}start`)?.value || '';
      const end = document.getElementById(`query-${prefix}end`)?.value || '';
      return { scope, event_filter: eventFilter, q, start_date: start, end_date: end };
    }

    function applyQueryFiltersToUI(filters, target = 'both') {
      if (!filters) return;
      const write = (prefix) => {
        const scopeEl = document.getElementById(`query-${prefix}scope`);
        const typeEl = document.getElementById(`query-${prefix}event-filter`);
        const qEl = document.getElementById(`query-${prefix}q`);
        const startEl = document.getElementById(`query-${prefix}start`);
        const endEl = document.getElementById(`query-${prefix}end`);
        if (scopeEl) scopeEl.value = (filters.scope || 'ALL');
        if (typeEl) typeEl.value = (filters.event_filter || 'ALL');
        if (qEl) qEl.value = filters.q || '';
        if (startEl) startEl.value = filters.start_date || '';
        if (endEl) endEl.value = filters.end_date || '';
      };
      if (target === 'main' || target === 'both') write('');
      if (target === 'modal' || target === 'both') write('modal-');
    }

    function saveQueryFilters() {
      try {
        localStorage.setItem(QUERY_FILTERS_KEY, JSON.stringify(readQueryFilters('modal')));
      } catch (_) {}
    }

    function loadQueryFilters() {
      let loaded = null;
      try {
        const raw = localStorage.getItem(QUERY_FILTERS_KEY);
        loaded = raw ? JSON.parse(raw) : null;
      } catch (_) {
        loaded = null;
      }
      if (loaded && loaded.start_date && loaded.end_date) {
        applyQueryFiltersToUI(loaded, 'both');
        return;
      }
      const today = new Date();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      const iso = `${today.getFullYear()}-${mm}-${dd}`;
      applyQueryFiltersToUI(
        {
          scope: 'ALL',
          event_filter: 'ALL',
          q: '',
          start_date: iso,
          end_date: iso,
        },
        'both'
      );
    }

    function syncQueryModalFromMain() {
      applyQueryFiltersToUI(readQueryFilters('main'), 'modal');
