    function normalizeFetchError(err) {
      return err && err.message ? String(err.message) : 'network error';
    }

    async function postEventOnline(payload) {
      try {
        const res = await fetch('/api/events', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const text = await res.text();
        const data = safeJsonParse(text, {});
        if (res.ok) return { ok: true, data, retriable: false };
        const detail = data.detail || text || t('k_event_failed');
        const asText = typeof detail === 'string' ? detail : JSON.stringify(detail);
        if (res.status === 409 && String(asText).includes('duplicate event_uuid')) {
          return { ok: true, data, retriable: false };
        }
        if (res.status >= 500) return { ok: false, retriable: true, error: asText };
        return { ok: false, retriable: false, error: asText };
      } catch (err) {
        return { ok: false, retriable: true, error: normalizeFetchError(err) };
      }
    }

    async function syncQueuedEvents() {
      if (offlineSyncInProgress || offlineMode) return;
      offlineSyncInProgress = true;
      renderOfflineStatus();
      try {
        const items = await idbGetAllByCreatedAt(OFFLINE_EVENTS_STORE);
        for (const item of items) {
          const sent = await postEventOnline(item);
          if (!sent.ok) {
            if (sent.retriable) {
              await setOfflineMode(true);
              break;
            }
            setText('event-toast', `${t('k_offline_sync_failed')} (${sent.error})`, true);
            await idbDelete(OFFLINE_EVENTS_STORE, item.event_uuid);
            offlineQueueCount = Math.max(0, offlineQueueCount - 1);
            renderOfflineStatus();
            continue;
          }
          await idbDelete(OFFLINE_EVENTS_STORE, item.event_uuid);
          offlineQueueCount = Math.max(0, offlineQueueCount - 1);
          renderOfflineStatus();
        }
      } catch (err) {
        setText('event-toast', `${t('k_offline_sync_failed')} (${normalizeFetchError(err)})`, true);
      } finally {
        offlineSyncInProgress = false;
        await loadOfflineQueueCount();
      }
    }

