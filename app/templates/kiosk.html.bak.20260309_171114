	    function _parseCode(code) {
	      const s = String(code || '').trim().toUpperCase();
	      if (!/^[A-Z][0-9][0-9][0-9][0-9]$/.test(s)) return null;
	      return { prefix: s[0], num: Number(s.slice(1)) };
	    }

	    function _nextPrefixLetter(ch) {
	      const c = String(ch || 'E').toUpperCase().charCodeAt(0);
	      if (Number.isNaN(c)) return 'E';
	      if (c >= 90) return null; // Z
	      return String.fromCharCode(c + 1);
	    }

	    function computeNextEmployeeCode() {
	      // Sequence starts at E0001; only move to next prefix when current prefix reaches 9999.
	      const maxByPrefix = {};
	      for (const r of adminEmployees || []) {
	        const p = _parseCode(r.employee_code);
	        if (!p) continue;
	        maxByPrefix[p.prefix] = Math.max(maxByPrefix[p.prefix] || 0, p.num);
	      }

	      let prefix = 'E';
	      while (true) {
	        const max = maxByPrefix[prefix] || 0;
	        if (max < 9999) {
	          const nextNum = max + 1;
	          return `${prefix}${String(nextNum).padStart(4, '0')}`;
	        }
	        const np = _nextPrefixLetter(prefix);
	        if (!np) return null;
	        prefix = np;
	      }
	    }

	    function applySuggestedEmployeeCode() {
	      const input = document.getElementById('new-code');
	      if (!input) return;
	      const next = computeNextEmployeeCode();
	      if (!next) return;
      input.value = next;
	      suggestedNextCode = next;
	    }

    function compareEmployeeCodes(a, b) {
      return String(a || '').localeCompare(String(b || ''), undefined, { numeric: true, sensitivity: 'base' });
    }

    function toggleEmployeeSort(key) {
      if (!key) return;
      if (employeeSortKey === key) {
        employeeSortDir = employeeSortDir === 'asc' ? 'desc' : 'asc';
      } else {
        employeeSortKey = key;
        employeeSortDir = 'asc';
      }
      renderEmployeeManage();
    }

    function updateEmployeeSortHeaders() {
      const map = {
        employee_code: 'emp-sort-code',
        name: 'emp-sort-name',
        hire_date: 'emp-sort-hire',
        termination_date: 'emp-sort-term',
        work_group: 'emp-sort-group',
        title: 'emp-sort-title',
        is_active: 'emp-sort-active',
        face_template_count: 'emp-sort-face',
      };
      for (const key of Object.keys(map)) {
        const th = document.getElementById(map[key]);
        if (!th) continue;
        th.classList.remove('sorted-asc', 'sorted-desc');
        if (employeeSortKey === key) {
          th.classList.add(employeeSortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
        }
      }
    }

    function _employeeSortValue(row, key) {
      if (key === 'employee_code') return String(row.employee_code || '');
      if (key === 'name') return String(row.name || '');
      if (key === 'hire_date') return String(row.hire_date || '');
      if (key === 'termination_date') return String(row.termination_date || '');
      if (key === 'work_group') return String(row.work_group || '');
      if (key === 'title') return String(row.title || '');
      if (key === 'is_active') return Number(!!row.is_active);
      if (key === 'face_template_count') return Number(row.face_template_count || 0);
      return '';
    }

    function compareEmployeeRows(a, b) {
      let cmp = 0;
      if (employeeSortKey === 'employee_code') {
        cmp = compareEmployeeCodes(a.employee_code, b.employee_code);
      } else if (employeeSortKey === 'is_active' || employeeSortKey === 'face_template_count') {
        const av = Number(_employeeSortValue(a, employeeSortKey));
        const bv = Number(_employeeSortValue(b, employeeSortKey));
        cmp = av - bv;
      } else {
        const av = String(_employeeSortValue(a, employeeSortKey) || '');
        const bv = String(_employeeSortValue(b, employeeSortKey) || '');
        cmp = av.localeCompare(bv, undefined, { numeric: true, sensitivity: 'base' });
      }
      if (cmp === 0) {
        cmp = compareEmployeeCodes(a.employee_code, b.employee_code);
      }
      return employeeSortDir === 'asc' ? cmp : -cmp;
    }


    function formatManageDateShort(dateStr) {
      const raw = String(dateStr || '').trim();
      if (!raw) return '';
      const m = raw.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (!m) return raw;
      const year = Number(m[1]);
      const month = Number(m[2]);
      const day = Number(m[3]);
      if (!year || !month || !day) return raw;
      return `${month}/${day}/${String(year).slice(-2)}`;
    }

    function syncManageDateDisplay(employeeId, field) {
      const id = String(employeeId || '');
      const dateEl = document.getElementById(`emp-${field}-${id}`);
      const labelEl = document.getElementById(`emp-${field}-label-${id}`);
      if (!dateEl || !labelEl) return;
      labelEl.textContent = formatManageDateShort(dateEl.value || '');
    }

    function openManageDatePicker(employeeId, field) {
      const id = String(employeeId || '');
      const dateEl = document.getElementById(`emp-${field}-${id}`);
      if (!dateEl) return;
      try {
        if (typeof dateEl.showPicker === 'function') {
          dateEl.showPicker();
          return;
        }
      } catch (_) {}
      try { dateEl.focus({ preventScroll: true }); } catch (_) { dateEl.focus(); }
      try { dateEl.click(); } catch (_) {}
