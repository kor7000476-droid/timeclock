	    async function identifyFace() {
	      if (cooldown) return;
	      const now = Date.now();

	      // Lightweight face presence detection so we can clear stale names after prolonged no-face.
	      const present = await detectFacePresence('camera');
	      if (present) {
	        lastFaceSeenAt = now;
	        idleWaiting = false;
	      } else {
	        // If a user was recognized, allow a short grace period to press a button after stepping away.
	        if (recognized) {
	          const dt = now - lastFaceSeenAt;
	          if (dt < ACTION_GRACE_MS) {
	            document.getElementById('scan-status').textContent = t('k_face_lost_grace');
	            return;
	          }
	          // Face is gone beyond grace: reset to waiting for the next user.
	          idleWaiting = true;
	          recognized = null;
	          renderRecognized();
	          document.getElementById('scan-status').textContent = t('k_waiting');
	          return;
	        }

	        if (now - lastFaceSeenAt >= 30000) {
	          // 30s idle: show waiting.
	          idleWaiting = true;
	          recognized = null;
	          renderRecognized();
	          document.getElementById('scan-status').textContent = t('k_waiting');
	          return;
	        }
	      }

	      const result = present ? await detectDescriptor('camera') : null;
	      if (!result) {
	        // Descriptor can fail intermittently; keep the last recognized during grace.
	        if (!recognized) renderRecognized();
	        document.getElementById('scan-status').textContent = idleWaiting ? t('k_waiting') : t('k_scan_align');
	        return;
	      }

      if (offlineMode) {
        await ensureOfflineFaceCacheReady();
        const localData = identifyFaceOffline(result.descriptor);
        applyIdentifyResult(localData, 'offline');
        return;
      }

      try {
        const res = await fetch('/api/identify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ embedding: result.descriptor, threshold: 0.50 }),
        });
        const text = await res.text();
        const data = safeJsonParse(text, {});
        if (!res.ok) throw new Error(data.detail || text || t('k_api_error'));
        updateLocalStatusFromServerIdentify(data);
        applyIdentifyResult(data, 'online');
      } catch (err) {
        console.error('identifyFace error', err);
        await setOfflineMode(true);
        await ensureOfflineFaceCacheReady();
        const localData = identifyFaceOffline(result.descriptor);
        applyIdentifyResult(localData, 'offline');
      }
	    }

