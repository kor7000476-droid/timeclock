    function safeJsonParse(text, fallback = {}) {
      try { return text ? JSON.parse(text) : fallback; } catch (_) { return fallback; }
    }

    function generateEventUuid() {
      try {
        if (window.crypto && typeof window.crypto.randomUUID === 'function') {
          return window.crypto.randomUUID();
        }
      } catch (_) {}
      return `evt-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
    }

    function utcNaiveIsoNow() {
      return new Date().toISOString().replace('Z', '');
    }

    function getAllowedEventsByStatus(status) {
      if (status === 'OFF') return ['CLOCK_IN'];
      if (status === 'WORKING') return ['CLOCK_OUT', 'BREAK_START'];
      if (status === 'BREAK') return ['BREAK_END'];
      return ['CLOCK_IN', 'CLOCK_OUT', 'BREAK_START', 'BREAK_END'];
    }

    function nextStatusByEvent(eventType) {
      if (eventType === 'CLOCK_IN') return 'WORKING';
      if (eventType === 'BREAK_START') return 'BREAK';
      if (eventType === 'BREAK_END') return 'WORKING';
      if (eventType === 'CLOCK_OUT') return 'OFF';
      return 'OFF';
    }

    function loadLocalStatusMap() {
      try {
        const raw = localStorage.getItem(LOCAL_STATUS_KEY);
        const parsed = raw ? JSON.parse(raw) : {};
        localStatusByEmployee = (parsed && typeof parsed === 'object') ? parsed : {};
      } catch (_) {
        localStatusByEmployee = {};
      }
    }

    function saveLocalStatusMap() {
      try {
        localStorage.setItem(LOCAL_STATUS_KEY, JSON.stringify(localStatusByEmployee || {}));
      } catch (_) {}
    }

    function updateLocalStatusFromServerIdentify(data) {
      const code = String(data?.employee_code || '').trim();
      const status = String(data?.status || '').trim();
      if (!code || !status) return;
      localStatusByEmployee[code] = status;
      saveLocalStatusMap();
    }

    function applyLocalEventStatus(employeeCode, eventType) {
      const code = String(employeeCode || '').trim();
      if (!code) return;
      const current = String(localStatusByEmployee[code] || '').trim();
      const allowed = getAllowedEventsByStatus(current || 'UNKNOWN');
      if (current && current !== 'UNKNOWN' && !allowed.includes(eventType)) {
        return;
      }
      localStatusByEmployee[code] = nextStatusByEvent(eventType);
      saveLocalStatusMap();
    }

    function getLocalAllowedEvents(employeeCode) {
      const code = String(employeeCode || '').trim();
      if (!code) return ['CLOCK_IN', 'CLOCK_OUT', 'BREAK_START', 'BREAK_END'];
      const status = String(localStatusByEmployee[code] || '').trim();
      return getAllowedEventsByStatus(status || 'UNKNOWN');
    }

    function openOfflineDb() {
      if (offlineDbPromise) return offlineDbPromise;
      offlineDbPromise = new Promise((resolve, reject) => {
        if (!window.indexedDB) {
          reject(new Error('IndexedDB unavailable'));
          return;
        }
        const req = window.indexedDB.open(OFFLINE_DB_NAME, OFFLINE_DB_VERSION);
        req.onupgradeneeded = () => {
          const db = req.result;
          if (!db.objectStoreNames.contains(OFFLINE_EVENTS_STORE)) {
            const store = db.createObjectStore(OFFLINE_EVENTS_STORE, { keyPath: 'event_uuid' });
            store.createIndex('created_at', 'created_at', { unique: false });
          }
          if (!db.objectStoreNames.contains(OFFLINE_META_STORE)) {
            db.createObjectStore(OFFLINE_META_STORE, { keyPath: 'key' });
          }
        };
        req.onsuccess = () => resolve(req.result);
        req.onerror = () => reject(req.error || new Error('offline db open failed'));
      });
      offlineDbPromise = offlineDbPromise.catch((err) => {
        offlineDbPromise = null;
        throw err;
      });
      return offlineDbPromise;
    }

    async function idbRun(storeName, mode, runner) {
      const db = await openOfflineDb();
      return await new Promise((resolve, reject) => {
        const tx = db.transaction(storeName, mode);
        const store = tx.objectStore(storeName);
        let out;
        try {
          out = runner(store);
        } catch (err) {
          reject(err);
          return;
        }
        tx.oncomplete = () => resolve(out);
        tx.onerror = () => reject(tx.error || new Error(`idb tx error: ${storeName}`));
        tx.onabort = () => reject(tx.error || new Error(`idb tx abort: ${storeName}`));
      });
    }

    async function idbPut(storeName, value) {
      await idbRun(storeName, 'readwrite', (store) => { store.put(value); });
    }

    async function idbDelete(storeName, key) {
      await idbRun(storeName, 'readwrite', (store) => { store.delete(key); });
    }

    async function idbGet(storeName, key) {
      const db = await openOfflineDb();
      return await new Promise((resolve, reject) => {
        const tx = db.transaction(storeName, 'readonly');
        const store = tx.objectStore(storeName);
        const req = store.get(key);
        req.onsuccess = () => resolve(req.result);
        req.onerror = () => reject(req.error || new Error(`idb get failed: ${storeName}`));
      });
    }

    async function idbCount(storeName) {
      const db = await openOfflineDb();
      return await new Promise((resolve, reject) => {
        const tx = db.transaction(storeName, 'readonly');
        const store = tx.objectStore(storeName);
        const req = store.count();
        req.onsuccess = () => resolve(Number(req.result || 0));
        req.onerror = () => reject(req.error || new Error(`idb count failed: ${storeName}`));
      });
    }

    async function idbGetAllByCreatedAt(storeName) {
      const db = await openOfflineDb();
      return await new Promise((resolve, reject) => {
        const tx = db.transaction(storeName, 'readonly');
        const store = tx.objectStore(storeName);
        const idx = store.index('created_at');
        const req = idx.getAll();
        req.onsuccess = () => resolve(Array.isArray(req.result) ? req.result : []);
        req.onerror = () => reject(req.error || new Error(`idb getAll failed: ${storeName}`));
      });
    }

    function renderOfflineStatus(extraMsg = '') {
      const onlineLabel = offlineMode ? t('k_offline_status_offline') : t('k_offline_status_online');
      const queueLabel = t('k_offline_queue');
      const blockTextBase = `${onlineLabel} · ${queueLabel} ${offlineQueueCount}`;
      let blockText = blockTextBase;
      if (offlineSyncInProgress) blockText += ` · ${t('k_offline_syncing')}`;
      if (extraMsg) blockText += ` · ${extraMsg}`;
      const inlineUnit = uiLang === 'ko' ? '건' : '';
      const inlineText = `[${onlineLabel} - ${queueLabel} ${offlineQueueCount}${inlineUnit}]`;
      const targets = [
        { id: 'offline-mode-status', text: blockText },
        { id: 'offline-mode-status-inline', text: inlineText },
      ];
      for (const item of targets) {
        const el = document.getElementById(item.id);
        if (!el) continue;
        el.textContent = item.text;
        el.classList.remove('hidden');
        el.classList.toggle('offline', !!offlineMode);
      }
    }

    function updateOfflineAlertCountdownText() {
      const el = document.getElementById('offline-alert-countdown');
      if (!el) return;
      el.innerHTML = `${t('k_offline_alert_countdown')} <span class="num">${Math.max(0, Number(offlineAlertRemaining || 0))}</span>s`;
    }

    function playOfflineAlertBeeps(count = 5) {
      const total = Math.max(1, Number(count || 5));
      try {
        const Ctx = window.AudioContext || window.webkitAudioContext;
        if (!Ctx) return;
        if (!_audioCtx) _audioCtx = new Ctx();
        if (_audioCtx.state === 'suspended') _audioCtx.resume().catch(() => {});
        const now = _audioCtx.currentTime;
        for (let index = 0; index < total; index += 1) {
          const t0 = now + (index * 0.23);
          const osc = _audioCtx.createOscillator();
          const gain = _audioCtx.createGain();
          osc.type = 'square';
          osc.frequency.setValueAtTime(920, t0);
          gain.gain.setValueAtTime(0.0001, t0);
          gain.gain.exponentialRampToValueAtTime(0.22, t0 + 0.01);
          gain.gain.exponentialRampToValueAtTime(0.0001, t0 + 0.12);
          osc.connect(gain);
          gain.connect(_audioCtx.destination);
          osc.start(t0);
          osc.stop(t0 + 0.14);
        }
      } catch (_) {}
    }

    function hideOfflineAlertPopup() {
      const backdrop = document.getElementById('offline-alert-backdrop');
      if (!backdrop) return;
      if (offlineAlertCountdownTimer) {
        clearInterval(offlineAlertCountdownTimer);
        offlineAlertCountdownTimer = null;
      }
      backdrop.classList.add('hidden');
      backdrop.setAttribute('aria-hidden', 'true');
      offlineAlertRemaining = 0;
    }

    function showOfflineAlertPopup() {
      if (!offlineMode) return;
      const backdrop = document.getElementById('offline-alert-backdrop');
      if (!backdrop) return;
      const titleEl = document.getElementById('offline-alert-title');
      const msgEl = document.getElementById('offline-alert-message');
      if (titleEl) titleEl.textContent = t('k_offline_alert_title');
      if (msgEl) msgEl.textContent = t('k_offline_alert_msg');
      offlineAlertRemaining = OFFLINE_ALERT_SECONDS;
      updateOfflineAlertCountdownText();
      backdrop.classList.remove('hidden');
      backdrop.setAttribute('aria-hidden', 'false');
      playOfflineAlertBeeps(5);
      if (offlineAlertCountdownTimer) clearInterval(offlineAlertCountdownTimer);
      offlineAlertCountdownTimer = setInterval(() => {
        offlineAlertRemaining -= 1;
        if (offlineAlertRemaining <= 0) {
          hideOfflineAlertPopup();
          return;
        }
        updateOfflineAlertCountdownText();
      }, 1000);
    }

    function startOfflineAlertLoop() {
      if (offlineAlertTimer) return;
      offlineAlertTimer = setInterval(() => {
        if (!offlineMode) return;
        showOfflineAlertPopup();
      }, OFFLINE_ALERT_INTERVAL_MS);
    }

    function stopOfflineAlertLoop() {
      if (offlineAlertTimer) {
        clearInterval(offlineAlertTimer);
        offlineAlertTimer = null;
      }
      hideOfflineAlertPopup();
    }

    async function setOfflineMode(nextOffline) {
      const changed = offlineMode !== !!nextOffline;
      offlineMode = !!nextOffline;
      if (offlineMode && offlineFaceCache.length === 0) {
        await ensureOfflineFaceCacheReady();
      }
      if (offlineMode) startOfflineAlertLoop();
      else stopOfflineAlertLoop();
      renderOfflineStatus();
      if (changed && offlineMode) {
        showOfflineAlertPopup();
      }
      if (changed && !offlineMode) {
        setText('event-toast', t('k_offline_synced'));
      }
    }

    async function loadOfflineQueueCount() {
      try {
        offlineQueueCount = await idbCount(OFFLINE_EVENTS_STORE);
      } catch (_) {
        offlineQueueCount = 0;
      }
      renderOfflineStatus();
