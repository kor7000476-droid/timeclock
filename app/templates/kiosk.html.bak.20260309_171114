    function normalizeAssetPath(urlLike) {
      try {
        return new URL(String(urlLike || ''), window.location.origin).pathname;
      } catch (_) {
        return '';
      }
    }

    function isOfflineModelAssetPath(pathname) {
      const path = String(pathname || '');
      return (
        path === '/static/vendor/face-api/face-api.js' ||
        path.startsWith('/static/vendor/face-api/model/')
      );
    }

    async function getCachedModelAsset(pathname) {
      if (!('caches' in window)) return null;
      const key = normalizeAssetPath(pathname);
      if (!key || !isOfflineModelAssetPath(key)) return null;
      try {
        const dedicated = await caches.open(OFFLINE_MODEL_CACHE_NAME);
        const dedicatedHit = await dedicated.match(key, { ignoreSearch: true });
        if (dedicatedHit) return dedicatedHit;
      } catch (_) {}
      try {
        return await caches.match(key, { ignoreSearch: true });
      } catch (_) {
        return null;
      }
    }

    async function putCachedModelAsset(pathname, response) {
      if (!('caches' in window)) return;
      if (!response || (!response.ok && response.type !== 'opaque')) return;
      const key = normalizeAssetPath(pathname);
      if (!key || !isOfflineModelAssetPath(key)) return;
      try {
        const dedicated = await caches.open(OFFLINE_MODEL_CACHE_NAME);
        await dedicated.put(key, response.clone());
      } catch (_) {}
    }

    async function loadScriptFromCache(pathname) {
      const key = normalizeAssetPath(pathname);
      const cached = await getCachedModelAsset(key);
      if (!cached) throw new Error(`script cache miss: ${key}`);
      const jsText = await cached.text();
      if (!jsText) throw new Error(`script cache empty: ${key}`);
      await new Promise((resolve, reject) => {
        const blob = new Blob([jsText], { type: 'text/javascript' });
        const blobUrl = URL.createObjectURL(blob);
        const script = document.createElement('script');
        script.src = blobUrl;
        script.async = true;
        script.onload = () => {
          try { URL.revokeObjectURL(blobUrl); } catch (_) {}
          resolve();
        };
        script.onerror = () => {
          try { URL.revokeObjectURL(blobUrl); } catch (_) {}
          reject(new Error(`script cache load failed: ${key}`));
        };
        document.head.appendChild(script);
      });
    }

    function patchFetchForOfflineModelAssets() {
      if (window.__timeclockOfflineModelFetchPatched) return;
      if (typeof window.fetch !== 'function') return;
      const nativeFetch = window.fetch.bind(window);
      window.fetch = async (input, init) => {
        let reqUrl = '';
        try {
          reqUrl = typeof input === 'string' ? input : (input && input.url) || '';
        } catch (_) {
          reqUrl = '';
        }
        const path = normalizeAssetPath(reqUrl);
        if (!isOfflineModelAssetPath(path)) {
          return nativeFetch(input, init);
        }
        const cached = await getCachedModelAsset(path);
        if (!navigator.onLine && cached) return cached.clone();
        try {
          const resp = await nativeFetch(input, init);
          await putCachedModelAsset(path, resp);
          return resp;
        } catch (err) {
          if (cached) return cached.clone();
          throw err;
        }
      };
      window.__timeclockOfflineModelFetchPatched = true;
    }

    function loadScriptOnce(src) {
      return new Promise((resolve, reject) => {
        const path = normalizeAssetPath(src);
        const isLocalModelScript = isOfflineModelAssetPath(path) && path.endsWith('/face-api.js');
        const fallbackLoad = async () => {
          if (isLocalModelScript) {
            await loadScriptFromCache(path);
            if (isFaceApiReady()) return;
          }
          throw new Error(`script load failed: ${src}`);
        };
        const existing = Array.from(document.querySelectorAll('script[src]')).find((node) => {
          const value = String(node.getAttribute('src') || '');
          return value === src || value.startsWith(src.split('?')[0]);
        });
        if (existing) {
          if (isFaceApiReady()) {
            resolve();
          } else {
            let settled = false;
            let waitId = null;
            const finishResolve = () => {
              if (settled) return;
              settled = true;
              if (waitId) clearTimeout(waitId);
              resolve();
            };
            const finishReject = (err) => {
              if (settled) return;
              settled = true;
              if (waitId) clearTimeout(waitId);
              reject(err);
            };
            const runFallback = async () => {
              try {
                await fallbackLoad();
                finishResolve();
              } catch (err) {
                finishReject(err instanceof Error ? err : new Error(`script load failed: ${src}`));
              }
            };
            waitId = setTimeout(() => {
              runFallback().catch(() => {});
            }, 1200);
            existing.addEventListener('load', () => finishResolve(), { once: true });
            existing.addEventListener('error', () => { runFallback().catch(() => {}); }, { once: true });
          }
          return;
        }
        if (!navigator.onLine && isLocalModelScript) {
          fallbackLoad().then(resolve).catch((err) => reject(err instanceof Error ? err : new Error(`script load failed: ${src}`)));
          return;
        }
        const script = document.createElement('script');
        script.src = src;
        script.async = true;
        script.onload = () => resolve();
        script.onerror = async () => {
          try {
            await fallbackLoad();
            resolve();
          } catch (err) {
            reject(err instanceof Error ? err : new Error(`script load failed: ${src}`));
          }
        };
        document.head.appendChild(script);
      });
    }

    async function ensureFaceApiLoaded() {
      if (isFaceApiReady()) return true;
