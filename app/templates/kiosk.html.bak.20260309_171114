    function syncQueryMainFromModal() {
      applyQueryFiltersToUI(readQueryFilters('modal'), 'main');
    }

    function updateQueryPager() {
      const info = document.getElementById('query-page-info');
      const prev = document.getElementById('query-page-prev');
      const next = document.getElementById('query-page-next');
      if (!info || !prev || !next) return;
      const total = queryTotalPages > 0 ? queryTotalPages : 1;
      const current = queryCurrentPage > 0 ? queryCurrentPage : 1;
      info.textContent = `${current} / ${total}`;
      prev.disabled = queryTotalPages <= 1 || queryCurrentPage <= 1;
      next.disabled = queryTotalPages <= 1 || queryCurrentPage >= queryTotalPages;
