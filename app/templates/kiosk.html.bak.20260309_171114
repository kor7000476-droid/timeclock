    async function warmOfflineModelAssets() {
      let okCount = 0;
      for (const url of OFFLINE_MODEL_ASSET_URLS) {
        const path = normalizeAssetPath(url);
        const cached = await getCachedModelAsset(path);
        if (cached) {
          okCount += 1;
          continue;
        }
        if (!navigator.onLine) continue;
        try {
          const res = await fetch(path, { cache: 'no-store' });
          if (res.ok || res.type === 'opaque') {
            await putCachedModelAsset(path, res);
            okCount += 1;
          }
        } catch (_) {}
      }
      return okCount === OFFLINE_MODEL_ASSET_URLS.length;
    }

    async function registerServiceWorker() {
      if (!('serviceWorker' in navigator)) return;
      try {
        const reg = await navigator.serviceWorker.register('/sw.js', { scope: '/' });
        if (reg.waiting) reg.waiting.postMessage({ type: 'SKIP_WAITING' });
        reg.addEventListener('updatefound', () => {
          const worker = reg.installing;
          if (!worker) return;
          worker.addEventListener('statechange', () => {
            if (worker.state === 'installed' && reg.waiting) {
              reg.waiting.postMessage({ type: 'SKIP_WAITING' });
            }
          });
        });
      } catch (err) {
        console.warn('service worker registration failed', err);
      }
    }

