          if (weekdayEl) {
            const weekday = Number(data.anchor_weekday);
            weekdayEl.value = Number.isInteger(weekday) && weekday >= 0 && weekday <= 6 ? String(weekday) : '0';
          }
          if (anchorStartEl) {
            if (data.anchor_start_date) anchorStartEl.value = String(data.anchor_start_date);
            else if (!anchorStartEl.value) anchorStartEl.value = '';
          }
	        if (emailEl) {
	          const current = (data.to_email || '').trim();
	          if (current) emailEl.value = current;
	          else if (!emailEl.value) {
	            const base = (document.getElementById('payroll-email-to')?.value || '').trim();
	            // Only copy a real email (avoid old cached store-id values like "store-001").
	            if (base.includes('@')) emailEl.value = base;
	          }
	        }
	        const statusEl = document.getElementById('auto-payroll-status');
	        if (statusEl) statusEl.textContent = '';
	      } catch (err) {
	        const statusEl = document.getElementById('auto-payroll-status');
	        if (statusEl) statusEl.textContent = '';
	        setText('auto-payroll-msg', err.message, true);
	      }
	    }

	    async function savePayrollAutoEmail() {
	      if (!adminPin) {
	        setText('auto-payroll-msg', tAdmin('a_msg_admin_required'), true);
	        return;
	      }
	      const enabled = !!document.getElementById('auto-payroll-enabled')?.checked;
	      const toEmail = (document.getElementById('auto-payroll-email')?.value || '').trim();
      const cycleWeeksRaw = Number(document.getElementById('auto-payroll-cycle-weeks')?.value || 2);
      const cycleWeeks = cycleWeeksRaw === 1 ? 1 : 2;
      const weekdayRaw = Number(document.getElementById('auto-payroll-anchor-weekday')?.value || 0);
      const anchorWeekday = (weekdayRaw >= 0 && weekdayRaw <= 6) ? weekdayRaw : 0;
      const anchorStartDate = (document.getElementById('auto-payroll-anchor-start')?.value || '').trim();
      const catchupOnce = !!document.getElementById('auto-payroll-catchup-once')?.checked;
	      if (enabled && !toEmail) {
	        setText('auto-payroll-msg', tAdmin('a_msg_auto_need_email'), true);
	        return;
	      }
	      try {
	        const res = await fetch('/api/admin/payroll-auto-email/config', {
	          method: 'POST',
	          headers: { 'Content-Type': 'application/json' },
	          body: JSON.stringify({
              admin_pin: adminPin,
              enabled,
              to_email: toEmail || null,
              cycle_weeks: cycleWeeks,
              anchor_weekday: anchorWeekday,
              anchor_start_date: anchorStartDate || null,
              catchup_once: catchupOnce,
            }),
	        });
	        const text = await res.text();
	        let data = {};
	        try { data = text ? JSON.parse(text) : {}; } catch (_) { data = {}; }
	        if (!res.ok || !data.ok) throw new Error(data.detail || text || tAdmin('a_msg_auto_save_failed'));
	        setText('auto-payroll-msg', tAdmin('a_msg_auto_saved'));
	        await loadPayrollAutoEmailStatus();
	      } catch (err) {
	        setText('auto-payroll-msg', err.message, true);
	      }
	    }

      // iPad/iOS Safari: prevent keyboard + backspace/delete from auto-scrolling the whole page.
      // Rule: while editing admin inputs, the page must not move unless the user scrolls manually.
      (function setupIOSScrollLock() {
        const isIOS = () => {
          try {
            return !!(window.CSS && CSS.supports && CSS.supports('-webkit-touch-callout: none')) &&
              /Apple/i.test(navigator.vendor || '') &&
              (navigator.maxTouchPoints || 0) > 1;
          } catch (_) {
            return false;
          }
        };
        if (!isIOS()) return;

        let locked = false;
        let savedY = 0;

        const isEditable = (el) => {
          if (!el || !el.tagName) return false;
          const tag = el.tagName.toLowerCase();
          return tag === 'input' || tag === 'textarea' || tag === 'select';
        };
        const inAdmin = (el) => {
          const admin = document.getElementById('admin-panel');
          return !!admin && admin.contains(el);
        };
        const shouldLock = (el) => isEditable(el) && inAdmin(el);

        const lock = () => {
          if (locked) return;
          savedY = window.scrollY || window.pageYOffset || 0;
          document.body.classList.add('ios-scroll-lock');
          document.body.style.top = `-${savedY}px`;
          locked = true;
        };
        const unlock = () => {
          if (!locked) return;
          document.body.classList.remove('ios-scroll-lock');
          document.body.style.top = '';
          window.scrollTo(0, savedY);
          locked = false;
        };

        // Lock as early as possible (before focus triggers Safari's scroll adjustments).
        document.addEventListener('touchstart', (e) => {
          const t = e.target;
          if (shouldLock(t)) lock();
        }, { passive: true, capture: true });
        document.addEventListener('focusin', (e) => {
          const t = e.target;
          if (shouldLock(t)) lock();
        }, true);
        document.addEventListener('focusout', () => {
          // If focus moves to another admin input, keep locked.
          setTimeout(() => {
            const a = document.activeElement;
            if (!shouldLock(a)) unlock();
          }, 50);
        }, true);
      })();

      // iPad/iOS Safari: suppress vertical rubber-band shake on kiosk/admin panels.
      (function setupIOSVerticalStability() {
        const isIOS = () => {
          try {
            return !!(window.CSS && CSS.supports && CSS.supports('-webkit-touch-callout: none')) &&
              /Apple/i.test(navigator.vendor || '') &&
              (navigator.maxTouchPoints || 0) > 1;
          } catch (_) {
            return false;
          }
        };
        if (!isIOS()) return;

        const panelIds = ['kiosk-panel', 'admin-panel'];
        const inTrackedPanel = (el) => {
          for (const id of panelIds) {
            const panel = document.getElementById(id);
            if (panel && panel.contains(el)) return true;
          }
          return false;
        };

        const findScrollable = (el) => {
          let cur = el;
          while (cur && cur !== document.body) {
            try {
              const style = window.getComputedStyle(cur);
              const canScrollY = (style.overflowY === 'auto' || style.overflowY === 'scroll') && (cur.scrollHeight > cur.clientHeight + 1);
              if (canScrollY) return cur;
            } catch (_) {}
            cur = cur.parentElement;
          }
          return null;
        };

        let startX = 0;
        let startY = 0;
        let activeScroller = null;

        document.addEventListener('touchstart', (e) => {
          const t = e.target;
          if (!inTrackedPanel(t)) {
            activeScroller = null;
            return;
          }
          const touch = e.touches && e.touches[0];
          if (!touch) return;
          startX = touch.clientX;
          startY = touch.clientY;
          activeScroller = findScrollable(t);
        }, { passive: true, capture: true });

        document.addEventListener('touchmove', (e) => {
          const t = e.target;
          if (!inTrackedPanel(t)) return;
          const touch = e.touches && e.touches[0];
          if (!touch) return;

          const dx = touch.clientX - startX;
          const dy = touch.clientY - startY;

          // Don't block horizontal drags.
          if (Math.abs(dx) > Math.abs(dy)) return;

          const scroller = activeScroller || findScrollable(t);
          if (!scroller) {
            e.preventDefault();
            return;
          }

          const top = scroller.scrollTop <= 0;
          const bottom = scroller.scrollTop + scroller.clientHeight >= scroller.scrollHeight - 1;
          const pullingDown = dy > 0;
          const pullingUp = dy < 0;

          if ((top && pullingDown) || (bottom && pullingUp)) {
            e.preventDefault();
          }
        }, { passive: false, capture: true });
      })();

      // iPad/iOS Safari: force zoom scale back to 1 immediately after pinch/zoom gestures.
      (function setupIOSZoomReset() {
        const isIOS = () => {
          try {
            return !!(window.CSS && CSS.supports && CSS.supports('-webkit-touch-callout: none')) &&
              /Apple/i.test(navigator.vendor || '') &&
              (navigator.maxTouchPoints || 0) > 1;
          } catch (_) {
            return false;
          }
        };
        if (!isIOS()) return;

        const viewportMeta = document.querySelector('meta[name="viewport"]');
        if (!viewportMeta) return;

        const lockViewport = 'width=device-width, initial-scale=1, viewport-fit=cover, minimum-scale=1, maximum-scale=1, user-scalable=no';
        const forceResetScale = () => {
          let scale = 1;
          try {
            if (window.visualViewport && typeof window.visualViewport.scale === 'number') {
              scale = window.visualViewport.scale;
            }
          } catch (_) {}
          if (Math.abs(scale - 1) < 0.01) return;
          viewportMeta.setAttribute('content', lockViewport);
          requestAnimationFrame(() => {
            viewportMeta.setAttribute('content', lockViewport);
          });
        };

        viewportMeta.setAttribute('content', lockViewport);

        document.addEventListener('gesturestart', (e) => {
          e.preventDefault();
          forceResetScale();
        }, { passive: false, capture: true });
        document.addEventListener('gesturechange', (e) => {
          e.preventDefault();
        }, { passive: false, capture: true });
        document.addEventListener('gestureend', (e) => {
          e.preventDefault();
          forceResetScale();
        }, { passive: false, capture: true });

        let resetTimer = null;
        const queueReset = () => {
          if (resetTimer) clearTimeout(resetTimer);
          resetTimer = setTimeout(forceResetScale, 0);
        };
        document.addEventListener('touchend', queueReset, { passive: true, capture: true });
        if (window.visualViewport && window.visualViewport.addEventListener) {
          window.visualViewport.addEventListener('resize', queueReset, { passive: true });
        }
        window.addEventListener('orientationchange', () => setTimeout(forceResetScale, 120), { passive: true });
        window.addEventListener('pageshow', () => setTimeout(forceResetScale, 60), { passive: true });
      })();

    window.addEventListener('load', init);
  </script>
