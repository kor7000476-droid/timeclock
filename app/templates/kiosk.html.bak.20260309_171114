	          confidence: data.confidence,
	          distance: data.distance,
	          status: data.status || null,
	          allowed_events: Array.isArray(data.allowed_events) ? data.allowed_events : null,
	        };
	        recognizedAt = Date.now();
	        lastFaceSeenAt = recognizedAt;
	        const statusText = source === 'offline'
	          ? `${t('k_offline_match_mode')} · ${t('k_verified_press')}`
	          : t('k_verified_press');
	        document.getElementById('scan-status').textContent = statusText;
	      } else {
	        recognized = null;
	        const reason = String(data?.reason || '').toUpperCase();
	        if (reason === 'AMBIGUOUS') {
	          document.getElementById('scan-status').textContent = t('k_ambiguous');
	        } else if (reason === 'NO_CACHE') {
	          document.getElementById('scan-status').textContent = t('k_offline_cache_missing');
